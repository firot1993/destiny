{
  "name": "destiny",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "HTTP_PROXY=$(scutil --proxy 2>/dev/null | awk '/HTTPEnable/{e=$3} /HTTPProxy /{h=$3} /HTTPPort /{p=$3} END{if(e==1) printf \"http://\" h \":\" p}') HTTPS_PROXY=$(scutil --proxy 2>/dev/null | awk '/HTTPSEnable/{e=$3} /HTTPSProxy /{h=$3} /HTTPSPort /{p=$3} END{if(e==1) printf \"http://\" h \":\" p}') next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "^15.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/ui": "^4.1.4",
    "eslint": "^8",
    "eslint-config-next": "^15.3.1",
    "jsdom": "^29.0.2",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
